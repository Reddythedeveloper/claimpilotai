# Environment Configuration Template

APP_ENV=production

# Database (PostgreSQL)
DATABASE_URL=postgresql+psycopg://user:password@db_host:5432/claimpilot_db

# Redis (Task Queue / Caching)
REDIS_URL=redis://redis_host:6379

# Vector DB (Qdrant)
QDRANT_URL=http://qdrant_host:6333

# Object Storage (MinIO / S3)
MINIO_ENDPOINT=minio_host:9000
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key

# LLM Providers (Groq)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL_PRIMARY=llama-3.1-8b-instant
GROQ_MODEL_CRITIC=llama-3.1-8b-instant

# Security
JWT_SECRET=super_secret_production_key_here

# Frontend Config
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Tracing & Observability (LangSmith)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=ClaimPilot-AI
